# ============================================================================
# Gateway Environment Configuration - TEMPLATE
# ----------------------------------------------------------------------------
# Copy to .env and fill in real values. NEVER commit .env.
# In production, use a secret manager (AWS Secrets Manager, Vault, SSM)
# and inject via docker secrets / k8s secrets / env from secret store.
# ============================================================================

# --- PostgreSQL (gateway/n8n) ---
POSTGRES_USER=gateway
POSTGRES_PASSWORD=CHANGE_ME  # openssl rand -base64 48
POSTGRES_DB=gateway

# --- Kong Database (only used if KONG_DATABASE=postgres; default is DB-less) ---
KONG_PG_USER=kong
KONG_PG_PASSWORD=CHANGE_ME
KONG_PG_DATABASE=kong

# --- n8n ---
N8N_BASIC_AUTH_USER=admin
N8N_BASIC_AUTH_PASSWORD=CHANGE_ME
# Persistent encryption key for credentials-at-rest. Generate with: openssl rand -hex 16
# CHANGING THIS INVALIDATES ALL STORED CREDENTIALS.
N8N_ENCRYPTION_KEY=CHANGE_ME
N8N_WEBHOOK_URL=https://gateway.example.com/
N8N_HOST=gateway.example.com
N8N_PROTOCOL=https

# --- Redis (n8n queue-mode broker) ---
REDIS_PASSWORD=CHANGE_ME

# --- Grafana ---
GF_SECURITY_ADMIN_USER=admin
GF_SECURITY_ADMIN_PASSWORD=CHANGE_ME

# --- Samsara ---
SAMSARA_API_TOKEN=CHANGE_ME
SAMSARA_WEBHOOK_SECRET=CHANGE_ME

# --- NetSuite (OAuth 1.0 TBA) ---
NETSUITE_ACCOUNT_ID=CHANGE_ME
NETSUITE_CONSUMER_KEY=CHANGE_ME
NETSUITE_CONSUMER_SECRET=CHANGE_ME
NETSUITE_TOKEN_ID=CHANGE_ME
NETSUITE_TOKEN_SECRET=CHANGE_ME

# --- WMS ---
WMS_API_URL=https://wms.example.com
WMS_API_KEY=CHANGE_ME

# --- Unigroup/EDI ---
EDI_SENDER_ID=CHANGE_ME
EDI_RECEIVER_ID=CHANGE_ME

# --- TLS ---
TLS_CERT_PATH=./config/kong/certs/server.crt
TLS_KEY_PATH=./config/kong/certs/server.key

# --- Alerting ---
ALERTMANAGER_SLACK_WEBHOOK=
ALERTMANAGER_PAGERDUTY_KEY=

# --- Backup encryption ---
BACKUP_AGE_RECIPIENT=
BACKUP_RETENTION_DAYS=30
