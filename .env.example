# Gateway Environment Configuration
# 
# IMPORTANT: This is a template file. DO NOT put real secrets here!
# Copy this to .env and fill in your actual values
# .env is gitignored and will never be committed

# PostgreSQL
POSTGRES_USER=gateway
POSTGRES_PASSWORD=CHANGE_ME_strong_password_here
POSTGRES_DB=gateway

# Kong Database
KONG_PG_USER=kong
KONG_PG_PASSWORD=CHANGE_ME_strong_password_here
KONG_PG_DATABASE=kong

# n8n
N8N_BASIC_AUTH_USER=admin
N8N_BASIC_AUTH_PASSWORD=CHANGE_ME_strong_password_here

# Grafana
GF_SECURITY_ADMIN_USER=admin
GF_SECURITY_ADMIN_PASSWORD=CHANGE_ME_strong_password_here

# Samsara API
# Get your API token from: https://cloud.samsara.com/settings/api-tokens
SAMSARA_API_TOKEN=your_samsara_token_here

# NetSuite API (OAuth 1.0)
# Get these from NetSuite → Setup → Integration → Manage Integrations
NETSUITE_ACCOUNT_ID=your_account_id
NETSUITE_CONSUMER_KEY=your_consumer_key
NETSUITE_CONSUMER_SECRET=your_consumer_secret
NETSUITE_TOKEN_ID=your_token_id
NETSUITE_TOKEN_SECRET=your_token_secret

# WMS API
WMS_API_URL=https://your-wms-api.com
WMS_API_KEY=your_wms_api_key

# Unigroup/EDI
EDI_SENDER_ID=your_sender_id
EDI_RECEIVER_ID=your_receiver_id
